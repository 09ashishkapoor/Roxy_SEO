    "index.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "omp": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": ">=14.4.1"
  },
  "devDependencies": {
