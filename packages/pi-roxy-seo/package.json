{
  "name": "@unseated7635/pi-roxy-seo",
  "version": "0.1.1",
  "description": "Roxy SEO extension for pi-coding-agent with an installable SEO, AEO, and GEO skill companion.",
  "author": "Ashish Kapoor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/09ashishkapoor/Roxy_SEO.git",
    "directory": "packages/pi-roxy-seo"
  },
  "homepage": "https://github.com/09ashishkapoor/Roxy_SEO/tree/main/packages/pi-roxy-seo#readme",
  "bugs": {
    "url": "https://github.com/09ashishkapoor/Roxy_SEO/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "keywords": [
